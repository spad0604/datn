<launch>
  <arg name="ws_url" default="ws://192.168.31.205:8080/ws-delivery-native"/>
  <arg name="api_base_url" default="http://192.168.31.205:8080/api/v1/robot"/>
  <arg name="secret_key" default="DATN_2025_2_GIAP"/>

  <arg name="enable_order_listener" default="true"/>
  <arg name="enable_update_location" default="true"/>
  <arg name="enable_listen_orders" default="false"/>

  <group if="$(arg enable_order_listener)">
    <node pkg="new_robot" type="ServerInterface.py" name="order_listener_sm" output="screen">
      <param name="ws_url" value="$(arg ws_url)"/>
      <param name="api_base_url" value="$(arg api_base_url)"/>
      <param name="secret_key" value="$(arg secret_key)"/>
    </node>
  </group>

  <group if="$(arg enable_update_location)">
    <node pkg="new_robot" type="UpdateLocation.py" name="update_location" output="screen">
      <param name="ws_url" value="$(arg ws_url)"/>
      <param name="api_base_url" value="$(arg api_base_url)"/>
      <param name="secret_key" value="$(arg secret_key)"/>
      <param name="interval_seconds" value="10"/>
      <param name="max_distance_meters" value="200.0"/>
    </node>
  </group>

  <group if="$(arg enable_listen_orders)">
    <node pkg="new_robot" type="listen_orders.py" name="listen_orders" output="screen"/>
  </group>
</launch>
